// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pengguna {
  id            String          @id @default(cuid())
  namaLengkap   String
  nomorHP       String
  email         String
  username      String          @unique
  password      String
  role          String          @default("user")
  createdAt     DateTime        @default(now())
  validUntil    DateTime?
  calonPembeli  CalonPembeli[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  companyName String?
  address     String
  phone       String
  email       String
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Paper {
  id          String   @id @default(cuid())
  name        String
  grammage    Int
  width       Float
  height      Float
  pricePerRim Float
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PrintingCost {
  id                          String   @id @default(cuid())
  machineName                 String
  grammage                    Int
  printAreaWidth              Float
  printAreaHeight             Float
  pricePerColor               Float
  specialColorPrice           Float
  minimumPrintQuantity        Int
  priceAboveMinimumPerSheet   Float
  platePricePerSheet          Float
  userId                      String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model Finishing {
  id              String   @id @default(cuid())
  name            String
  minimumSheets   Int
  minimumPrice    Float
  additionalPrice Float
  pricePerCm      Float
  userId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CalonPembeli {
  id          String    @id @default(cuid())
  nama        String
  nomorHP     String
  email       String
  alamat      String
  catatan     String
  status      String    @default("baru")
  role        String    @default("demo")
  expiredDate DateTime?
  username    String?
  password    String?
  userId      String?
  pengguna    Pengguna? @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Pembeli {
  id          String    @id @default(cuid())
  nama        String
  nomorHP     String
  email       String
  alamat      String
  catatan     String
  role        String    @default("demo")
  expiredDate DateTime?
  userId      String?
  penggunaId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RiwayatCetakan {
  id                  String   @id @default(cuid())
  printName           String
  customerName         String   @default("")
  paperName           String
  paperGrammage       String
  paperLength         String
  paperWidth          String
  cutWidth            String
  cutHeight           String
  quantity            String
  warna               String
  warnaKhusus         String
  machineName         String
  hargaPlat           Float
  ongkosCetak         Float
  ongkosCetakDetail   String
  machineName2        String    @default("")
  ongkosCetak2        Float     @default(0)
  ongkosCetak2Detail  String    @default("")
  totalPaperPrice     Float
  finishingNames      String
  finishingBreakdown  String
  finishingCost       Float
  packingCost         Float
  shippingCost        Float
  otherCost           Float    @default(0)
  glueCost            Float    @default(0)
  glueBorongan        Float    @default(0)
  subTotal            Float
  profitPercent       Float
  profitAmount        Float
  grandTotal          Float
  userId              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Payment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  packageName     String
  packageType     String   // bulanan, tahunan, lifetime
  grossAmount     Float
  customerName    String   @default("")
  customerEmail   String   @default("")
  customerPhone   String   @default("")
  paymentType     String?
  transactionId   String?
  transactionTime DateTime?
  transactionStatus String   @default("pending")
  fraudStatus     String?
  userId          String?
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Invoice {
  id                String   @id @default(cuid())
  invoiceNumber     String   @unique
  customerName      String
  customerAddress   String   @default("")
  customerPhone     String   @default("")
  customerEmail     String   @default("")
  invoiceDate       String
  dueDate           String   @default("")
  items             String   // JSON array of invoice items
  subTotal          Float    @default(0)
  discount          Float    @default(0)
  tax               Float    @default(0)
  grandTotal        Float    @default(0)
  notes             String   @default("")
  status            String   @default("draft") // draft, sent, paid, cancelled
  riwayatCetakanId  String?
  userId            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  currency    String   @default("IDR")
  interval    String   @default("monthly") // monthly, yearly, lifetime
  features    String   @default("[]") // JSON array
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subscriptions UserSubscription[]
}

model UserSubscription {
  id              String   @id @default(cuid())
  userId          String
  planId          String
  plan            SubscriptionPlan @relation(fields: [planId], references: [id])
  status          String   @default("active") // active, cancelled, expired, past_due
  startDate       DateTime @default(now())
  endDate         DateTime?
  autoRenew       Boolean  @default(true)
  paymentMethodId String?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PaymentMethod {
  id            String   @id @default(cuid())
  userId        String
  type          String   @default("bank_transfer") // bank_transfer, ewallet, credit_card
  label         String
  provider      String   @default("")
  accountNumber String   @default("")
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  payments      PaymentRecord[]
}

model PaymentRecord {
  id                String   @id @default(cuid())
  userId            String
  subscriptionId    String?
  paymentMethodId   String?
  paymentMethod     PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  amount            Float
  currency          String   @default("IDR")
  status            String   @default("pending") // pending, success, failed, refunded
  paymentType       String   @default("subscription") // subscription, topup
  provider          String   @default("")
  transactionId     String   @unique
  vaNumber          String   @default("")
  ewalletUrl        String   @default("")
  retryCount        Int      @default(0)
  maxRetry          Int      @default(3)
  nextRetryAt       DateTime?
  paidAt            DateTime?
  expiredAt         DateTime?
  metadata          String   @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info") // info, warning, error, success
  isRead    Boolean  @default(false)
  link      String   @default("")
  createdAt DateTime @default(now())
}

model SuratJalan {
  id                String   @id @default(cuid())
  suratJalanNumber  String   @unique
  customerName      String
  customerAddress   String   @default("")
  customerPhone     String   @default("")
  driverName        String   @default("")
  vehicleNumber     String   @default("")
  deliveryDate      String
  items             String   // JSON array of delivery items
  notes             String   @default("")
  status            String   @default("draft") // draft, delivered, cancelled
  invoiceId         String?
  riwayatCetakanId  String?
  userId            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
