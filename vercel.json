{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "darrellpos",
  "framework": "nextjs",
  "buildCommand": "node scripts/prepare-build.js && npx prisma db push --skip-generate --accept-data-loss && npx prisma generate && npx next build",
  "installCommand": "bun install",
  "regions": ["sin1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
